# Salin ke .env lokal atau set di Vercel → Settings → Environment Variables

# Neon: WAJIB pakai connection string "Pooled" / host dengan "-pooler" untuk serverless (Vercel).
# Di Neon Console: Dashboard project → Connection details → tab yang menyebut Pooling / Transaction mode.
# Region dekat Indonesia: AWS Asia Pacific (Singapore) — aws-ap-southeast-1
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Opsional — membatasi pool di setiap instance serverless (kurangi "connection storm")
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
# Putuskan koneksi idle/lama agar tidak memakai sesi yang sudah ditutup Neon
DB_CONN_MAX_LIFETIME_SEC=300
DB_CONN_MAX_IDLE_SEC=120
